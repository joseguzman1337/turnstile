  ],
  "description": "Access-control proxy service for APIs",
  "scripts": {
    "test": "mocha",
    "cover": "rm -Rf docs/coverage && istanbul cover _mocha",
    "doc": "rm -Rf docs/jsdoc && jsdoc -c .jsdoc.json lib",
    "lint": "eslint bin/* lib/* test/*.js test/**/*.js",
    "report": "coveralls < ./docs/coverage/lcov.info",
    "clean": "rm -rf docs/jsdoc docs/coverage docs/_site"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rapid7/turnstile.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rapid7/turnstile/issues"
  },
  "homepage": "https://github.com/rapid7/turnstile#readme",
  "devDependencies": {
    "chai": "~6.2.2",
    "coveralls": "~3.1.1",
    "eslint": "~10.0.3",
    "eslint-config-rapid7": "~3.1.0",
    "eslint-plugin-import": "~2.32.0",
    "istanbul": "~0.4.5",
    "jsdoc": "~4.0.5",
    "mocha": "~11.7.5",
    "nock": "~14.0.11",
    "node-mocks-http": "~1.17.2"
  },
  "dependencies": {
    "body-parser": "~2.2.2",
    "bytes": "~3.1.2",
    "conditional": "~5.3.0",
    "express": "~5.2.1",
    "express-http-proxy": "~2.1.2",
    "hot-shots": "~14.2.0",
    "nconf": "~0.13.0",
    "request": "~2.88.2",
    "request-promise-native": "~1.0.9",
    "uuid": "~13.0.0",
    "winston": "~3.19.0"
  }
